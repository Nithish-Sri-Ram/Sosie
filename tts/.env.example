# Copy to tts/.env. PROMPT_WAV is the voice to clone (3-10s clean mono clip);
# PROMPT_TEXT must be the EXACT words spoken in that clip (transcribe it, e.g.
# with stt/smoke_test.py). Example below clones the Elon sample in ../assets.
PROMPT_WAV=/home/Sosie/tts/assets/prompt.wav
PROMPT_TEXT=Resources, so you've got access to water or frozen water, that you're not too close to the poles, so you can use solar power. It would be nice to use nuclear.

# optional overrides:
# COSYVOICE_DIR=./CosyVoice
# COSYVOICE_MODEL=./CosyVoice/pretrained_models/CosyVoice2-0.5B
# PORT=5002
