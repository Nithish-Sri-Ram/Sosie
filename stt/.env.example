# Copy to stt/.env to override. All optional — defaults work on Mac (CPU/int8).
# WHISPER_MODEL=base          # tiny | base | small | medium | large-v3
# WHISPER_DEVICE=cpu          # cpu on Mac (CTranslate2 has no MPS); cuda on GPU box
# WHISPER_COMPUTE=int8        # int8 (cpu) | float16 (cuda)
# PORT=5001
