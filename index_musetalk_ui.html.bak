<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Sosie - Talk to Elon (v4 live avatar)</title>
<style>
  :root { color-scheme: dark; }
  body { font-family: system-ui, sans-serif; background: #0b0e14; color: #e6e6e6;
         max-width: 640px; margin: 0 auto; padding: 32px 16px 120px; }
  header { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  #face { position: relative; width: 200px; height: 200px; border-radius: 24px;
          border: 3px solid #333; overflow: hidden;
          transition: box-shadow .2s, border-color .2s, width .3s, height .3s; }
  #avatar, #avatarvid { position: absolute; inset: 0; width: 100%; height: 100%;
                        object-fit: cover; }
  #avatarvid { display: none; }
  #face.video #avatarvid { display: block; }
  #face.listening { border-color: #d33; box-shadow: 0 0 0 6px rgba(221,51,51,.25); }
  #face.speaking  { width: 300px; height: 300px; border-color: #3a7afe;
                    animation: pulse 1.1s ease-in-out infinite; }
  @keyframes pulse {
    0%,100% { box-shadow: 0 0 0 4px rgba(58,122,254,.35); }
    50%     { box-shadow: 0 0 0 12px rgba(58,122,254,.12); }
  }
  h1 { font-size: 18px; font-weight: 600; margin: 0; }
  #status { color: #8a91a0; min-height: 20px; font-size: 14px; }
  #log { margin-top: 20px; display: flex; flex-direction: column; gap: 8px; }
  .line { padding: 10px 14px; border-radius: 12px; max-width: 85%;
          line-height: 1.4; white-space: pre-wrap; }
  .you   { background: #1d2635; align-self: flex-end; }
  .you.live { opacity: .6; }
  .elon  { background: #16211a; align-self: flex-start; }
  .elon::before { content: "Elon"; display: block; font-size: 11px; color: #7cba8d; margin-bottom: 2px; }
  #bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; justify-content: center;
         padding: 16px; background: linear-gradient(transparent, #0b0e14 40%); }
  #talk { padding: 14px 34px; font-size: 16px; border: 0; border-radius: 999px;
          background: #e6e6e6; color: #111; cursor: pointer; font-weight: 600; }
  #talk.rec { background: #d33; color: #fff; }
  #talk:disabled { opacity: .5; cursor: default; }
</style>
</head>
<body>
  <header>
    <div id="face">
      <img id="avatar" src="assets/Elon_Musk.jpg" alt="Elon Musk" />
      <video id="avatarvid" playsinline></video>
    </div>
    <h1>Talk to Elon</h1>
    <div id="status">Press the button, then just talk - Elon answers when you pause</div>
  </header>
  <div id="log"></div>
  <div id="bar"><button id="talk">Start conversation</button></div>

<script>
  // Backends. Three ways this page can be served:
  //  - localhost:8000 (serve.py, dev)          -> backends on their own ports
  //  - Caddy HTTPS proxy :8443                 -> same-origin /stt /llm /tts
  //  - JarvisLabs-style port proxy /proxy/8000 -> sibling /proxy/<port> paths
  // Override via ?stt=..&llm=..&tts=.. if needed.
  const q = new URLSearchParams(location.search);
  let sttDef, llmDef, ttsDef, vidDef;
  if (location.pathname.match(/^\/proxy\/\d+\//)) {
    sttDef = location.origin + "/proxy/5001";
    llmDef = "/proxy/5004";
    ttsDef = "/proxy/5002";
    vidDef = "/proxy/5003";
  } else if (location.port === "8000") {
    sttDef = "http://localhost:5001";
    llmDef = "http://localhost:5004";
    ttsDef = "http://localhost:5002";
    vidDef = "http://localhost:5003";
  } else {
    sttDef = location.origin + "/stt";
    llmDef = "/llm";
    ttsDef = "/tts";
    vidDef = "/vid";
  }
  const STT_WS = (q.get("stt") || sttDef).replace(/^http/, "ws");
  const LLM = q.get("llm") || llmDef;
  const TTS = q.get("tts") || ttsDef;
  const VID = q.get("vid") || vidDef;

  const btn = document.getElementById("talk");
  const statusEl = document.getElementById("status");
  const log = document.getElementById("log");
  const face = document.getElementById("face");
  const vid = document.getElementById("avatarvid");

  let audioCtx, processor, source, stream, socket;
  let running = false;   // conversation on/off
  let muted = false;     // true while Elon thinks/speaks (mic frames dropped)
  let transcript = "", liveEl = null;
  let idleURL = null;    // pre-rendered silent loop: Elon looks alive between turns

  async function loadIdle() {
    try {
      const r = await fetch(VID + "/idle");
      if (!r.ok) return;
      idleURL = URL.createObjectURL(await r.blob());
      playIdle();
    } catch (e) { /* vid_gen down - keep the photo */ }
  }

  function playIdle() {
    if (!idleURL) return;
    vid.onended = null; vid.onerror = null; vid.onplay = null;
    vid.src = idleURL;
    vid.loop = true;
    vid.muted = true;
    vid.play().then(() => face.classList.add("video")).catch(() => {});
  }
  loadIdle();

  function line(cls, text) {
    const d = document.createElement("div");
    d.className = "line " + cls;
    d.textContent = text;
    log.appendChild(d);
    d.scrollIntoView({ behavior: "smooth", block: "end" });
    return d;
  }

  // Groq LLM (server-side proxy holds the key). Falls back to echo if offline.
  async function reply(userText) {
    if (!userText) return "I didn't catch that - say that again?";
    try {
      const r = await fetch(LLM + "/chat", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ text: userText }),
      });
      return (await r.json()).reply || "...";
    } catch (e) { return "You said: " + userText; }  // LLM offline - echo
  }

  // --- audio helpers (mic -> 16kHz Int16 PCM) ---
  function toPCM16(f32) {
    const out = new Int16Array(f32.length);
    for (let i = 0; i < f32.length; i++) {
      const s = Math.max(-1, Math.min(1, f32[i]));
      out[i] = s < 0 ? s * 0x8000 : s * 0x7fff;
    }
    return out;
  }
  function downsample(buf, inRate, outRate) {
    if (outRate === inRate) return buf;
    const ratio = inRate / outRate, len = Math.round(buf.length / ratio);
    const res = new Float32Array(len);
    let o = 0, b = 0;
    while (o < len) {
      const next = Math.round((o + 1) * ratio);
      let acc = 0, c = 0;
      for (let i = b; i < next && i < buf.length; i++) { acc += buf[i]; c++; }
      res[o++] = acc / (c || 1);
      b = next;
    }
    return res;
  }

  btn.onclick = () => { running ? stop() : start(); };

  function listening() {
    muted = false;
    face.classList.add("listening");
    statusEl.textContent = "Listening... just talk, pause when done";
  }

  async function start() {
    transcript = "";
    try {
      stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    } catch (e) {
      statusEl.textContent = "Mic blocked - the page must be https (or localhost) and the mic allowed.";
      return;
    }
    audioCtx = new AudioContext();
    socket = new WebSocket(STT_WS + "/ws");
    socket.binaryType = "arraybuffer";

    socket.onerror = () => { statusEl.textContent = "Can't reach STT server on " + STT_WS; };
    socket.onmessage = (e) => {
      if (typeof e.data !== "string") return;          // ignore stray binary frames
      if (e.data === "[[END]]") { turnEnd(); return; } // turn detected (Silero VAD)
      if (e.data === "[[S]]") {                        // speech onset
        if (!liveEl) liveEl = line("you live", "...");
        return;
      }
      if (e.data.startsWith("[[P]]")) {                // live partial transcript
        if (!liveEl) liveEl = line("you live", "...");
        liveEl.textContent = e.data.slice(5);
        return;
      }
      transcript = e.data;                             // final utterance transcript
      if (!liveEl) liveEl = line("you live", "...");
      liveEl.textContent = transcript;
    };

    socket.onopen = () => {
      source = audioCtx.createMediaStreamSource(stream);
      processor = audioCtx.createScriptProcessor(4096, 1, 1);
      processor.onaudioprocess = (e) => {
        if (muted || socket.readyState !== WebSocket.OPEN) return;
        const pcm = toPCM16(downsample(e.inputBuffer.getChannelData(0), audioCtx.sampleRate, 16000));
        socket.send(pcm.buffer);
      };
      source.connect(processor);
      processor.connect(audioCtx.destination);  // silent (no output written)
      running = true;
      btn.textContent = "End conversation";
      btn.classList.add("rec");
      listening();
    };
  }

  function stop() {
    running = false;
    muted = true;
    btn.textContent = "Start conversation";
    btn.classList.remove("rec");
    face.classList.remove("listening", "speaking");
    playIdle();
    statusEl.textContent = "Press the button, then just talk - Elon answers when you pause";
    if (processor) processor.disconnect();
    if (source) source.disconnect();
    if (audioCtx) audioCtx.close();
    if (stream) stream.getTracks().forEach(t => t.stop());
    if (socket) socket.close();
    liveEl = null;
    transcript = "";
  }

  // one conversational turn: transcript is in, get Elon's reply and speak it
  async function turnEnd() {
    if (!running) return;
    muted = true;                       // don't let Elon hear himself
    face.classList.remove("listening");
    const userText = transcript.trim();
    transcript = "";
    if (liveEl) { liveEl.classList.remove("live"); liveEl.textContent = userText || "(unclear)"; }
    liveEl = null;
    if (!userText) { listening(); return; }

    statusEl.textContent = "Thinking...";
    const answer = await reply(userText);
    if (!running) return;
    line("elon", answer);

    statusEl.textContent = "Generating voice...";
    try {
      const r = await fetch(TTS + "/tts", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ text: answer }),
      });
      if (!r.ok) throw new Error("TTS " + r.status);
      const wav = await r.blob();
      if (!running) return;
      if (await speakVideo(wav)) return;   // lip-synced video (MuseTalk)
      await speakAudio(wav);               // fallback: voice only
    } catch (e) {
      statusEl.textContent = "TTS error: " + e.message;
      if (running) listening();
    }
  }

  // MuseTalk lip-sync. Preferred path: fragmented mp4 streamed while frames
  // are generated, played live via MediaSource. Falls back to whole-file mp4,
  // and returns false if vid_gen is down so the caller can go voice-only.
  const MSE_CODEC = 'video/mp4; codecs="avc1.42E01F, mp4a.40.2"';

  async function speakVideo(wav) {
    if (window.MediaSource && MediaSource.isTypeSupported(MSE_CODEC)) {
      if (await speakVideoStream(wav)) return true;
    }
    return await speakVideoBlob(wav);
  }

  function videoDone(resolve, ok) {
    face.classList.remove("speaking");
    playIdle();                      // back to the living idle loop
    if (running) listening();
    resolve(ok);
  }

  async function speakVideoStream(wav) {
    try {
      statusEl.textContent = "Rendering video...";
      const r = await fetch(VID + "/generate_stream", {
        method: "POST", headers: { "Content-Type": "audio/wav" }, body: wav,
      });
      if (!r.ok || !r.body) return false;
      const reader = r.body.getReader();
      const ms = new MediaSource();
      vid.loop = false;
      vid.muted = false;
      vid.src = URL.createObjectURL(ms);
      await new Promise((res) => ms.addEventListener("sourceopen", res, { once: true }));
      const sb = ms.addSourceBuffer(MSE_CODEC);
      const idle = () => new Promise((res) => {
        if (!sb.updating) return res();
        sb.addEventListener("updateend", res, { once: true });
      });
      let started = false;
      return await new Promise(async (resolve) => {
        vid.onended = () => videoDone(resolve, true);
        vid.onerror = () => { if (!started) resolve(false); else videoDone(resolve, true); };
        try {
          while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            await idle();
            sb.appendBuffer(value);
            if (!started) {
              started = true;
              vid.play().then(() => {
                face.classList.add("video", "speaking");
                statusEl.textContent = "Speaking... (live)";
              }).catch(() => resolve(false));
            }
          }
          await idle();
          if (ms.readyState === "open") ms.endOfStream();
          if (!started) resolve(false);   // stream ended before anything played
        } catch (e) {
          if (!started) resolve(false); else videoDone(resolve, true);
        }
      });
    } catch (e) { return false; }
  }

  async function speakVideoBlob(wav) {
    try {
      statusEl.textContent = "Rendering video...";
      const r = await fetch(VID + "/generate", {
        method: "POST", headers: { "Content-Type": "audio/wav" }, body: wav,
      });
      if (!r.ok) return false;
      const mp4 = await r.blob();
      if (!running) return true;
      return await new Promise((resolve) => {
        vid.loop = false;
        vid.muted = false;
        vid.src = URL.createObjectURL(mp4);
        vid.onplay = () => { face.classList.add("video", "speaking"); statusEl.textContent = "Speaking..."; };
        vid.onended = () => videoDone(resolve, true);
        vid.onerror = () => { face.classList.remove("speaking"); playIdle(); resolve(false); };
        vid.play().catch(() => { playIdle(); resolve(false); });
      });
    } catch (e) { return false; }
  }

  async function speakAudio(wav) {
    const audio = new Audio(URL.createObjectURL(wav));
    audio.onplay = () => { face.classList.add("speaking"); statusEl.textContent = "Speaking..."; };
    audio.onended = () => {
      face.classList.remove("speaking");
      playIdle();
      if (running) listening();
    };
    try { await audio.play(); }
    catch (e) {
      face.classList.remove("speaking");
      playIdle();
      if (running) listening();
    }
  }
</script>
</body>
</html>
